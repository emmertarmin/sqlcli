{
  "name": "sqlcli",
  "version": "0.1.0",
  "description": "A personal SQL CLI with current support for Microsoft SQL Server.",
  "license": "MIT",
  "repository": "github:emmertarmin/sqlcli",
  "type": "module",
  "bin": {
    "sqlcli": "./src/index.ts"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "tsc": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "mssql": "^11.0.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
